# ==========================================
# SearchEasy 环境变量配置
# 复制为 .env 后填入实际值
# ==========================================

# ── LLM (必填) ──────────────────────────
# 阿里云百炼 API Key: https://bailian.console.aliyun.com/
LLM_API_KEY=sk-your-api-key-here

# 模型选择 (qwen-turbo / qwen-plus / qwen-max)
LLM_MODEL=qwen-plus

# API 地址 (默认国内主域名)
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1


# ── 检索引擎 ────────────────────────────
# 特征库文件路径 (extract_features.py 的输出)
FEATURES_NPZ=features.npz

# 商品图片目录
IMAGE_DIR=product_images

# 检索返回数量
TOP_K=5

# 最低相似度阈值 (0~1)
MIN_SIMILARITY=0.0

# 图片对外访问 URL 前缀 (部署时设为实际域名)
# IMAGE_BASE_URL=https://your-domain.com
